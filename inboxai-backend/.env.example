# ─── App ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# No trailing slash. In dev, this is your ngrok URL; in prod, your Render URL.
APP_BASE_URL=https://your-host.example.com

# ─── PostgreSQL ──────────────────────────────────────────────────────────
# Single URL. Works with Neon / Railway / Fly / local docker-compose.
# Local docker-compose default: postgresql://postgres:postgres@127.0.0.1:5432/inboxai
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Redis (BullMQ) ──────────────────────────────────────────────────────
# Single URL. Use rediss:// for managed Redis (Upstash). Local: redis://localhost:6379
# Grab from Upstash dashboard → "Connect to your database" → ioredis tab.
REDIS_URL=redis://localhost:6379

# ─── Google OAuth ────────────────────────────────────────────────────────
# GCP Console → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web app)
GOOGLE_CLIENT_ID=xxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxx
GOOGLE_REDIRECT_URI=https://your-host.example.com/gmail/oauth/callback

# ─── Gmail Pub/Sub ───────────────────────────────────────────────────────
# Full topic name: projects/<gcp-project-id>/topics/<topic-name>
GOOGLE_PUBSUB_TOPIC=projects/your-gcp-project/topics/inboxai
# Audience for JWT verification on the push — set this to your webhook URL in the
# Pub/Sub subscription config.
PUBSUB_AUDIENCE=https://your-host.example.com/gmail/webhook
# Service account GCP uses to sign the push JWT (set under "Enable authentication"
# on the subscription).
PUBSUB_SERVICE_ACCOUNT_EMAIL=your-sa@your-gcp-project.iam.gserviceaccount.com

# ─── Gemini ──────────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your-key

# ─── Outbound email (Resend SMTP) ────────────────────────────────────────
# https://resend.com — free tier works without a domain, but you can only send
# to your own Resend account email until you verify a domain.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxx
# Default Resend test sender. Replace with `"InboxAI" <noreply@yourdomain.com>`
# once a domain is verified on Resend.
MAIL_FROM=InboxAI <onboarding@resend.dev>

# ─── Crypto ──────────────────────────────────────────────────────────────
# 32-byte hex key used to AES-encrypt OAuth refresh tokens at rest.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-chars

# ─── Workflow seeder ─────────────────────────────────────────────────────
# Used by WorkflowSeeder on first boot (when the workflows table is empty)
# as the recipient for default rules like "Forward job opportunities".
SEED_FORWARD_EMAIL=you@example.com
